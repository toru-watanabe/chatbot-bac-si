# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "groq" (default, free) or "gemini"
LLM_PROVIDER=groq

# ── Groq API Key (FREE) ───────────────────────────────────────────────────────
# Get yours at: https://console.groq.com (free account, no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# ── Gemini API Key (fallback) ─────────────────────────────────────────────────
# Get yours at: https://aistudio.google.com/apikey
# NOTE: regenerate your key if it was previously exposed
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/chatbot.db
